generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model check_results {
  id           Int       @id @default(autoincrement())
  siteId       Int?
  status       String
  responseTime Int?
  statusCode   Int?
  errorMessage String?
  checked_at   DateTime? @default(now())
  sites        sites?    @relation(fields: [siteId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([siteId, checked_at], map: "check_results_siteid_checked_at_index")
}

model knex_migrations {
  id             Int       @id @default(autoincrement())
  name           String?
  batch          Int?
  migration_time DateTime?
}

model knex_migrations_lock {
  index     Int  @id @default(autoincrement())
  is_locked Int?
}

model screenshots {
  id         Int       @id @default(autoincrement())
  siteId     Int?
  image_data Bytes?
  width      Int?
  height     Int?
  checked_at DateTime? @default(now())
  sites      sites?    @relation(fields: [siteId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([siteId, checked_at], map: "screenshots_siteid_checked_at_index")
}

model sites {
  id             Int             @id @default(autoincrement())
  name           String
  url            String
  checkInterval  Int?            @default(5)
  isActive       Boolean?        @default(true)
  userId         Int?
  check_type     String?         @default("http")
  expected_text  String?
  text_condition String?         @default("contains")
  created_at     DateTime        @default(now())
  updated_at     DateTime        @default(now())
  check_results  check_results[]
  screenshots    screenshots[]
  users          users?          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  speed_results  speed_results[]
  ssl_results    ssl_results[]
}

model speed_results {
  id               Int       @id @default(autoincrement())
  siteId           Int?
  loadTime         Int?
  ttfb             Int?
  domContentLoaded Int?
  pageSize         Int?
  requestCount     Int?
  error            String?
  checked_at       DateTime? @default(now())
  sites            sites?    @relation(fields: [siteId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([siteId, checked_at], map: "speed_results_siteid_checked_at_index")
}

model ssl_results {
  id         Int       @id @default(autoincrement())
  siteId     Int?
  valid      Boolean
  expired    Boolean
  daysLeft   Int
  validFrom  DateTime?
  validTo    DateTime?
  issuer     String?
  error      String?
  checked_at DateTime? @default(now())
  sites      sites?    @relation(fields: [siteId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([siteId, checked_at], map: "ssl_results_siteid_checked_at_index")
}

model users {
  id          Int       @id @default(autoincrement())
  email       String    @unique(map: "users_email_unique")
  password    String
  webhook_url String?
  is_admin    Boolean?  @default(false)
  max_sites   Int?      @default(4)
  banned_at   DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())
  sites       sites[]
}
