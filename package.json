{
  "name": "vigil",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Nikolay Alekseev",
  "description": "Modern status page with real-time monitoring",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "migrate": "knex migrate:latest --knexfile db/knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile db/knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile db/knexfile.ts",
    "seed": "knex seed:run --knexfile db/knexfile.ts",
    "seed:make": "knex seed:make --knexfile db/knexfile.ts",
    "db:init": "node db/init.js"
  },
  "dependencies": {
    "@nuxt/ui": "^2.20.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@pinia/nuxt": "^0.7.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@vueuse/nuxt": "^11.3.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.4.7",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "nuxt": "^3.15.4",
    "puppeteer": "^24.39.1",
    "sqlite3": "^5.1.7",
    "sslko": "^2.0.5",
    "vue-chartjs": "^5.3.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/puppeteer": "^7.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
