{
  "name": "vigil",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Nikolay Alekseev",
  "description": "Modern status page with real-time monitoring",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "analyze": "nuxt analyze",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "nuxt prepare",
    "db:init": "mkdir -p db && node db/init.ts",
    "db:reset": "npx prisma migrate reset --force --schema prisma/schema.prisma && node db/init.ts",
    "db:migrate": "npx prisma migrate dev --schema prisma/schema.prisma",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@nuxt/ui": "^2.20.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@pinia/nuxt": "^0.7.0",
    "@prisma/client": "5.22.0",
    "@prisma/nuxt": "^0.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@vueuse/nuxt": "^11.3.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.4.7",
    "chartjs-node-canvas": "^5.0.0",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "nuxt": "^3.15.4",
    "playwright": "^1.58.2",
    "prisma": "5.22.0",
    "sslko": "^2.0.5",
    "vue-chartjs": "^5.3.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
