{
  "name": "vigil",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Nikolay Alekseev",
  "description": "Modern status page with real-time monitoring",
  "scripts": {
    "dev": "nuxt dev",
    "typecheck": "nuxt typecheck",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "analyze": "nuxt analyze",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "prisma generate --schema prisma/schema.prisma && nuxt prepare && node scripts/install-playwright.mjs",
    "playwright:install": "playwright install chromium",
    "db:init": "mkdir -p db && node db/init.ts",
    "db:reset": "npx prisma migrate reset --force --schema prisma/schema.prisma && node db/init.ts",
    "db:migrate": "npx prisma migrate dev --schema prisma/schema.prisma",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@prisma/client": "5.22.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^11.3.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.4.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^3.15.4",
    "playwright": "^1.58.2",
    "prisma": "5.22.0",
    "reka-ui": "^2.9.6",
    "shadcn-nuxt": "^2.6.2",
    "sslko": "^2.0.5",
    "tailwind-merge": "^3.5.0",
    "vue-chartjs": "^5.3.2",
    "vue-sonner": "^1.3.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.4",
    "shadcn-vue": "^2.6.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.0"
  }
}
